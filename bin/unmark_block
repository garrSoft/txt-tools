#!/usr/bin/env bash
set -euo pipefail

MODE="${1:-}"
FILE="${2:-}"
LABEL="${3:-}"

if [[ -z "$MODE" || -z "$FILE" ]]; then
  echo "Usage: unmark_block <list|remove> <file> [label]" >&2
  exit 1
fi

if [[ ! -f "$FILE" ]]; then
  echo "File not found: $FILE" >&2
  exit 1
fi

case "$MODE" in
  list)
    grep -n "EXTRACT_" "$FILE" || true
    ;;
  remove)
    if [[ -z "$LABEL" ]]; then
      echo "remove requires a label" >&2
      exit 1
    fi

    TMP="$(mktemp)"

    awk -v label="$LABEL" '
      BEGIN { skip=0 }
      {
        if ($0 ~ "EXTRACT_CANDIDATE_BEGIN: " label) { next }
        if ($0 ~ "EXTRACT_TARGET:") { next }
        if ($0 ~ "EXTRACT_CANDIDATE_END: " label) { next }
        print
      }
    ' "$FILE" > "$TMP"

    MODE_PERM="$(stat -c '%a' "$FILE" 2>/dev/null || echo 644)"
    mv "$TMP" "$FILE"
    chmod "$MODE_PERM" "$FILE"

    echo
    echo "=== markers after remove ==="
    grep -n "EXTRACT_" "$FILE" || true
    ;;
  *)
    echo "Unknown mode: $MODE" >&2
    exit 1
    ;;
esac
