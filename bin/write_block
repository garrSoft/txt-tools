#!/usr/bin/env bash
set -euo pipefail

DRY_RUN=0
ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

set -- "${ARGS[@]}"

MODE="${1:-}"
FILE="${2:-}"
PATTERN="${3:-}"

if [[ -z "$MODE" || -z "$FILE" ]]; then
  echo "Usage: write_block <mode> <file> [pattern]" >&2
  exit 1
fi

# -------------------------
# STRICT STDIN READ (FIX)
# -------------------------
CONTENT=""
while IFS= read -r line; do
  CONTENT+="$line"$'\n'
done

CONTENT="${CONTENT%$'\n'}"

if [[ -z "$CONTENT" ]]; then
  echo "ERROR: empty input blocked"
  exit 1
fi

TMP="$(mktemp)"
printf "%s" "$CONTENT" > "$TMP"

# -------------------------
# DRY RUN
# -------------------------
if [[ "$DRY_RUN" -eq 1 ]]; then
  echo "=== DRY RUN ==="
  echo "MODE: $MODE"
  echo "FILE: $FILE"
  echo "CONTENT:"
  cat "$TMP"
  rm -f "$TMP"
  exit 0
fi

case "$MODE" in
  write)
    mv "$TMP" "$FILE"
    ;;

  append)
    cat "$TMP" >> "$FILE"
    rm -f "$TMP"
    ;;

  *)
    echo "Invalid mode: $MODE" >&2
    rm -f "$TMP"
    exit 1
    ;;
esac

echo
echo "=== verify: $FILE ==="
sed -n '1,200p' "$FILE"
